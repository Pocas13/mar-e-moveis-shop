# Base de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mar_e_moveis_shop?schema=public"

# Aplicacao
NEXTAUTH_URL="http://localhost:3004"
NEXTAUTH_SECRET="substituir-por-segredo-forte"
NEXT_PUBLIC_SITE_URL="http://localhost:3004"

# Stripe — deixar vazio enquanto nao estiver configurado
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="Mar e Moveis <loja@exemplo.pt>"

# Sage One Portugal API v2
# Manter desativado ate concluir OAuth e validacao fiscal.
SAGE_MODE="disabled"
SAGE_CLIENT_ID=""
SAGE_CLIENT_SECRET=""
SAGE_SIGNING_SECRET=""
SAGE_REDIRECT_URI="http://localhost:3004/api/integracoes/sage/callback"
SAGE_ACCESS_TOKEN=""
SAGE_REFRESH_TOKEN=""

# Desenvolvimento
# O atualizador cria/atualiza os dados ficticios por defeito.
# Alterar para false quando deixar de ser um ambiente de demonstracao.
SEED_DEMO="true"
