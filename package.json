{
  "name": "mar-e-moveis-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3004",
    "dev:alt": "next dev -p 3005",
    "build": "next build",
    "start": "next start -p 3004",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "prisma validate && prisma generate && tsc --noEmit",
    "db:setup": "prisma migrate dev --name mar_integracoes && npm run seed",
    "prisma:migrate": "prisma migrate dev",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed.ts",
    "check": "prisma validate && prisma generate && tsc --noEmit && next build",
    "update:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\atualizar.ps1"
  },
  "dependencies": {
    "@prisma/client": "5.17.0",
    "bcryptjs": "2.4.3",
    "next": "15.5.21",
    "next-auth": "4.24.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "3.5.0",
    "stripe": "22.3.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "autoprefixer": "10.4.19",
    "postcss": "8.5.10",
    "prisma": "5.17.0",
    "tailwindcss": "3.4.7",
    "tsx": "4.16.2",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
